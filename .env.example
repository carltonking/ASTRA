# LLM
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ASTRA_LLM_PROVIDER=anthropic

# Data sources
LSEG_APP_KEY=
POLYGON_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Broker (default: alpaca)
ASTRA_BROKER=alpaca
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
APCA_PAPER_URL=https://paper-api.alpaca.markets
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_ACCOUNT_ID=
TRADIER_TOKEN=
TRADIER_ACCOUNT_ID=

# Notifications
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_FROM=
NOTIFY_TO=

# Storage
ASTRA_BUILD_DIR=.astra_builds
ASTRA_EXPORT_DIR=.astra_exports
ASTRA_DB_PATH=.astra/astra.db

# Graduation gates
MIN_DSR=1.5
MIN_ANNUAL_RETURN=0.05
MAX_DRAWDOWN=0.20
MIN_TRADES=20
MAX_DEGRADATION=0.2
MIN_CALENDAR_DAYS=5
